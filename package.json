{
  "name": "image-feast-organizer",
  "version": "1.0.0",
  "description": "Desktop app to organize images by date and Traditional Catholic feast day",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
  "exifr": "^7.1.3"
},
"devDependencies": {
  "electron": "^31.0.0",
  "electron-builder": "^24.13.3"
},
  "build": {
    "appId": "com.local.imagefeastorganizer",
    "productName": "Image Feast Organizer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "calendar.js",
      "renderer/**/*",
      "calendar-data/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
